---
import CartaLayout from '../layouts/CartaLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:5000/api';
const token = Astro.url.searchParams.get('t');

if (!token) return Astro.redirect('/');

const accesoRes = await fetch(`${API_URL}/qr/validar/${token}`);
const acceso = await accesoRes.json();
if (!acceso.valido) return Astro.redirect('/?error=token-invalido');

const sucursalId = acceso.sucursalId;

const [platosRes, ofertasRes, conveniosRes, personalizacionRes, avisosRes] = await Promise.all([
  fetch(`${API_URL}/platos/buscar/${sucursalId}?soloDisponibles=true`),
  fetch(`${API_URL}/ofertas/por-sucursal/${sucursalId}`),
  fetch(`${API_URL}/convenios-tarjeta/por-sucursal/${sucursalId}`),
  fetch(`${API_URL}/personalizacion-carta/${sucursalId}`),
  fetch(`${API_URL}/avisos/por-sucursal/${sucursalId}`),
]);

const platos = await platosRes.json();
const ofertas = (await ofertasRes.json()).filter((o: any) => o.esActiva);
const convenios = (await conveniosRes.json()).filter((c: any) => c.esActivo);
const personalizacion = await personalizacionRes.json();
const avisos = (await avisosRes.json()).filter((a: any) => a.esActivo);

const categorias = [...new Set(platos.map((p: any) => p.categoria).filter(Boolean))] as string[];
const sugerenciasDia = platos.filter((p: any) => p.esSugerenciaDelDia);
const sugerenciasChef = platos.filter((p: any) => p.esSugerenciaDelChef);

const formatPrice = (n: number) => n.toLocaleString('es-AR');
const DIAS = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
const isVideo = (url?: string | null) => !!url && /\.(mp4|webm)$/i.test(url);
---

<CartaLayout
  title="La Trattoría de Nonna"
  fuenteTitulos={personalizacion.fuenteTitulos ?? 'Playfair Display'}
  fuenteCuerpo={personalizacion.fuenteCuerpo ?? 'Inter'}
>
  <div class="carta">
    <!-- Header -->
    <header class="header">
      <div class="header-ornament">
        <span class="ornament-line"></span>
        <span class="ornament-diamond">&#9670;</span>
        <span class="ornament-line"></span>
      </div>
      <h1 class="restaurant-name">La Trattoría<br/><span class="restaurant-sub">de Nonna</span></h1>
      <p class="restaurant-tagline">Cocina italiana de tradición familiar</p>
      <p class="mesa-badge">Mesa {acceso.numeroMesa}</p>
      <div class="header-ornament">
        <span class="ornament-line"></span>
        <span class="ornament-diamond">&#9670;</span>
        <span class="ornament-line"></span>
      </div>
    </header>

    <!-- Avisos -->
    {avisos.length > 0 && (
      <section class="avisos">
        {avisos.map((a: any) => (
          <div class="aviso">
            <span class="aviso-dot">&#8226;</span>
            {a.contenido}
          </div>
        ))}
      </section>
    )}

    <!-- Buscador -->
    <div class="search-container">
      <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" id="buscar" placeholder="Buscar en la carta..." class="search-input" />
    </div>

    <!-- Categorías -->
    {categorias.length > 0 && (
      <div class="categorias">
        <button class="cat-pill active" data-cat="todas">Todas</button>
        {categorias.map((cat) => (
          <button class="cat-pill" data-cat={cat}>{cat}</button>
        ))}
      </div>
    )}

    <!-- Sugerencia del día (Hero) -->
    {sugerenciasDia.length > 0 && (
      <section class="section">
        <div class="section-label">
          <span class="label-line"></span>
          <span class="label-text">Sugerencia del día</span>
          <span class="label-line"></span>
        </div>
        {sugerenciasDia.map((p: any) => (
          <a href={`/plato/${p.id}?t=${token}`} class="hero-card plato-card" data-nombre={p.nombre.toLowerCase()} data-descripcion={p.descripcion.toLowerCase()} data-categoria={p.categoria?.toLowerCase() ?? ''}>
            <div class="hero-img-wrap">
              {isVideo(p.imagenUrl) ? <video src={p.imagenUrl} class="hero-img" autoplay loop muted playsinline /> : <img src={p.imagenUrl} alt={p.nombre} class="hero-img" loading="lazy" />}
              <div class="hero-badge">Del Día</div>
            </div>
            <div class="hero-info">
              <h3 class="hero-title">{p.nombre}</h3>
              <p class="hero-desc">{p.descripcion}</p>
              <div class="hero-price">${formatPrice(p.precioActual)}</div>
            </div>
          </a>
        ))}
      </section>
    )}

    <!-- Sugerencia del chef -->
    {sugerenciasChef.length > 0 && (
      <section class="section">
        <div class="section-label">
          <span class="label-line"></span>
          <span class="label-text">Del Chef</span>
          <span class="label-line"></span>
        </div>
        {sugerenciasChef.map((p: any) => (
          <a href={`/plato/${p.id}?t=${token}`} class="chef-card plato-card" data-nombre={p.nombre.toLowerCase()} data-descripcion={p.descripcion.toLowerCase()} data-categoria={p.categoria?.toLowerCase() ?? ''}>
            {isVideo(p.imagenUrl) ? <video src={p.imagenUrl} class="chef-img" autoplay loop muted playsinline /> : <img src={p.imagenUrl} alt={p.nombre} class="chef-img" loading="lazy" />}
            <div class="chef-info">
              <div class="chef-badge">Chef</div>
              <h3 class="chef-title">{p.nombre}</h3>
              <p class="chef-desc">{p.descripcion}</p>
              <div class="chef-price">${formatPrice(p.precioActual)}</div>
            </div>
          </a>
        ))}
      </section>
    )}

    <!-- Carta completa por categoría -->
    {categorias.map((cat) => (
      <section class="section cat-section" data-category={cat.toLowerCase()}>
        <div class="section-label">
          <span class="label-line"></span>
          <span class="label-text">{cat}</span>
          <span class="label-line"></span>
        </div>
        <div class="platos-grid">
          {platos.filter((p: any) => p.categoria === cat).map((p: any) => (
            <a href={`/plato/${p.id}?t=${token}`} class="plato-item plato-card" data-nombre={p.nombre.toLowerCase()} data-descripcion={p.descripcion.toLowerCase()} data-categoria={p.categoria?.toLowerCase() ?? ''}>
              <div class="plato-thumb-wrap">
                {isVideo(p.imagenUrl) ? <video src={p.imagenUrl} class="plato-thumb" autoplay loop muted playsinline /> : <img src={p.imagenUrl} alt={p.nombre} class="plato-thumb" loading="lazy" />}
              </div>
              <div class="plato-info">
                <h4 class="plato-name">{p.nombre}</h4>
                <p class="plato-desc">{p.descripcion}</p>
                {p.datosNutricionales && <p class="plato-kcal">{p.datosNutricionales.split('·')[0].trim()}</p>}
              </div>
              <div class="plato-price">${formatPrice(p.precioActual)}</div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <!-- Ofertas -->
    {ofertas.length > 0 && (
      <section class="section">
        <div class="section-label">
          <span class="label-line"></span>
          <span class="label-text">Promociones</span>
          <span class="label-line"></span>
        </div>
        <div class="ofertas-list">
          {ofertas.map((o: any) => (
            <div class="oferta-card">
              <div class="oferta-accent"></div>
              <div class="oferta-body">
                <h4 class="oferta-title">{o.titulo}</h4>
                <p class="oferta-desc">{o.descripcion}</p>
                <p class="oferta-when">{DIAS[o.diaSemana]} · {o.horaInicio} a {o.horaFin}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Convenios -->
    {convenios.length > 0 && (
      <section class="section">
        <div class="section-label">
          <span class="label-line"></span>
          <span class="label-text">Beneficios con tarjeta</span>
          <span class="label-line"></span>
        </div>
        <div class="convenios-list">
          {convenios.map((c: any) => (
            <div class="convenio-card">
              <div class="convenio-pct">{c.porcentajeDescuento}%</div>
              <div>
                <h4 class="convenio-name">{c.nombreTarjeta}</h4>
                <p class="convenio-desc">{c.descripcion}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="footer">
      <div class="header-ornament">
        <span class="ornament-line"></span>
        <span class="ornament-diamond">&#9670;</span>
        <span class="ornament-line"></span>
      </div>
      <p class="footer-text">Powered by <strong>Crumble</strong></p>
    </footer>

    <!-- Llamar al mozo -->
    <button id="btn-mozo" class="mozo-btn" data-api={API_URL} data-sucursal-id={sucursalId} data-mesa-id={acceso.numeroMesa}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mozo-icon"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      <span class="mozo-text">Llamar al mozo</span>
    </button>
  </div>

  <style>
    .carta {
      max-width: 480px;
      margin: 0 auto;
      padding: 0 20px 120px;
    }

    /* Header */
    .header {
      text-align: center;
      padding: 48px 0 32px;
    }
    .restaurant-name {
      font-size: 36px;
      letter-spacing: 1px;
      color: var(--text);
      margin: 16px 0 8px;
    }
    .restaurant-sub {
      font-weight: 400;
      font-style: italic;
      font-size: 28px;
      color: var(--gold);
    }
    .restaurant-tagline {
      font-size: 13px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 12px;
    }
    .mesa-badge {
      display: inline-block;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold-light);
      padding: 4px 16px;
      border-radius: 20px;
      margin-bottom: 16px;
    }

    /* Ornaments */
    .header-ornament {
      display: flex;
      align-items: center;
      gap: 12px;
      justify-content: center;
    }
    .ornament-line {
      display: block;
      width: 60px;
      height: 1px;
      background: var(--gold-light);
    }
    .ornament-diamond {
      color: var(--gold);
      font-size: 8px;
    }

    /* Avisos */
    .avisos {
      margin-bottom: 24px;
    }
    .aviso {
      text-align: center;
      font-size: 13px;
      color: var(--text-light);
      padding: 8px 0;
      border-bottom: 1px solid var(--divider);
    }
    .aviso:last-child { border-bottom: none; }
    .aviso-dot { color: var(--gold); margin-right: 6px; }

    /* Search */
    .search-container {
      position: relative;
      margin-bottom: 20px;
    }
    .search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: var(--text-muted);
    }
    .search-input {
      width: 100%;
      padding: 14px 16px 14px 48px;
      background: var(--white);
      border: 1px solid var(--divider);
      border-radius: var(--radius-sm);
      font-family: var(--font-body);
      font-size: 15px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .search-input:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(196, 149, 106, 0.1);
    }
    .search-input::placeholder { color: var(--text-muted); }

    /* Categorías */
    .categorias {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      padding-bottom: 4px;
      margin-bottom: 32px;
      scrollbar-width: none;
    }
    .categorias::-webkit-scrollbar { display: none; }
    .cat-pill {
      flex-shrink: 0;
      padding: 8px 18px;
      border-radius: 24px;
      border: 1px solid var(--divider);
      background: var(--white);
      font-family: var(--font-body);
      font-size: 13px;
      font-weight: 500;
      color: var(--text-light);
      cursor: pointer;
      transition: all 0.2s;
    }
    .cat-pill.active, .cat-pill:hover {
      background: var(--text);
      color: var(--white);
      border-color: var(--text);
    }

    /* Section labels */
    .section { margin-bottom: 36px; }
    .section-label {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 20px;
    }
    .label-line {
      flex: 1;
      height: 1px;
      background: var(--divider);
    }
    .label-text {
      font-family: var(--font-display);
      font-size: 14px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold);
      white-space: nowrap;
    }

    /* Hero card (sugerencia del día) */
    .hero-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: var(--white);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .hero-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .hero-img-wrap { position: relative; }
    .hero-img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      display: block;
    }
    .hero-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      background: var(--gold);
      color: white;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 20px;
    }
    .hero-info { padding: 20px 24px 24px; }
    .hero-title { font-size: 22px; margin-bottom: 8px; }
    .hero-desc {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .hero-price {
      font-family: var(--font-display);
      font-size: 20px;
      color: var(--gold);
    }

    /* Chef card */
    .chef-card {
      display: flex;
      text-decoration: none;
      color: inherit;
      background: var(--white);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .chef-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .chef-img {
      width: 140px;
      min-height: 160px;
      object-fit: cover;
      flex-shrink: 0;
    }
    .chef-info { padding: 16px 20px; flex: 1; }
    .chef-badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold-light);
      padding: 2px 10px;
      border-radius: 12px;
      margin-bottom: 8px;
    }
    .chef-title { font-size: 17px; margin-bottom: 6px; }
    .chef-desc {
      font-size: 13px;
      color: var(--text-light);
      line-height: 1.4;
      margin-bottom: 10px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .chef-price {
      font-family: var(--font-display);
      font-size: 18px;
      color: var(--gold);
    }

    /* Plato items */
    .platos-grid { display: flex; flex-direction: column; gap: 12px; }
    .plato-item {
      display: flex;
      align-items: center;
      gap: 16px;
      text-decoration: none;
      color: inherit;
      background: var(--white);
      border-radius: var(--radius-sm);
      padding: 12px;
      box-shadow: var(--shadow-sm);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .plato-item:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-md);
    }
    .plato-thumb-wrap {
      width: 72px;
      height: 72px;
      border-radius: 10px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .plato-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .plato-info { flex: 1; min-width: 0; }
    .plato-name {
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .plato-desc {
      font-size: 12px;
      color: var(--text-light);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      line-height: 1.4;
    }
    .plato-kcal {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 4px;
    }
    .plato-price {
      font-family: var(--font-display);
      font-size: 16px;
      color: var(--text);
      flex-shrink: 0;
      padding-left: 8px;
    }

    /* Ofertas */
    .ofertas-list { display: flex; flex-direction: column; gap: 12px; }
    .oferta-card {
      display: flex;
      background: var(--white);
      border-radius: var(--radius-sm);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .oferta-accent {
      width: 4px;
      background: linear-gradient(180deg, var(--gold), var(--gold-light));
      flex-shrink: 0;
    }
    .oferta-body { padding: 16px 20px; }
    .oferta-title { font-family: var(--font-body); font-weight: 600; font-size: 15px; margin-bottom: 4px; }
    .oferta-desc { font-size: 13px; color: var(--text-light); margin-bottom: 6px; }
    .oferta-when { font-size: 12px; color: var(--gold); font-weight: 500; }

    /* Convenios */
    .convenios-list { display: flex; flex-direction: column; gap: 12px; }
    .convenio-card {
      display: flex;
      align-items: center;
      gap: 16px;
      background: var(--white);
      border-radius: var(--radius-sm);
      padding: 16px 20px;
      box-shadow: var(--shadow-sm);
    }
    .convenio-pct {
      font-family: var(--font-display);
      font-size: 28px;
      color: var(--gold);
      flex-shrink: 0;
      width: 64px;
      text-align: center;
    }
    .convenio-name { font-family: var(--font-body); font-weight: 600; font-size: 15px; margin-bottom: 2px; }
    .convenio-desc { font-size: 13px; color: var(--text-light); }

    /* Footer */
    .footer {
      text-align: center;
      padding: 40px 0;
    }
    .footer-text {
      margin-top: 16px;
      font-size: 12px;
      color: var(--text-muted);
      letter-spacing: 1px;
    }

    /* Mozo button */
    .mozo-btn {
      position: fixed;
      bottom: 24px;
      right: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--text);
      color: var(--white);
      border: none;
      padding: 14px 24px;
      border-radius: 50px;
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      box-shadow: var(--shadow-lg);
      transition: transform 0.15s, background 0.2s;
      z-index: 100;
    }
    .mozo-btn:hover { transform: scale(1.03); }
    .mozo-btn:active { transform: scale(0.97); }
    .mozo-btn.called { background: var(--gold); }
    .mozo-icon { width: 18px; height: 18px; }

    /* Hide filtered */
    .plato-card[style*="display: none"] { display: none !important; }
  </style>

  <script>
    const buscar = document.getElementById('buscar') as HTMLInputElement;
    const cards = document.querySelectorAll('.plato-card');
    const catBtns = document.querySelectorAll('.cat-pill');
    const catSections = document.querySelectorAll('.cat-section');
    const mozoBtn = document.getElementById('btn-mozo') as HTMLElement;
    const API = mozoBtn?.dataset.api ?? 'http://localhost:5000/api';
    const SUCURSAL_ID = mozoBtn?.dataset.sucursalId;
    let categoriaActiva = 'todas';

    function trackear(tipoEvento: string, referenciaId: string | null = null, metadata: string | null = null) {
      if (!SUCURSAL_ID) return;
      fetch(`${API}/metricas/evento`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sucursalId: SUCURSAL_ID, tipoEvento, referenciaId, metadata }),
      }).catch(() => {});
    }

    // Registrar scan QR al cargar
    trackear('scan_qr');

    // Filtro + tracking de búsqueda (debounced, dispara al detenerse 1.5s, mín 2 chars)
    let searchTimer: ReturnType<typeof setTimeout>;
    let lastQuery = '';
    buscar?.addEventListener('input', () => {
      filtrar();
      const q = buscar.value.trim();
      clearTimeout(searchTimer);
      if (q.length >= 2 && q !== lastQuery) {
        searchTimer = setTimeout(() => {
          lastQuery = q;
          trackear('busqueda_carta', null, q);
        }, 1500);
      }
    });

    catBtns.forEach(btn => btn.addEventListener('click', () => {
      categoriaActiva = (btn as HTMLElement).dataset.cat ?? 'todas';
      catBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filtrar();
    }));

    function filtrar() {
      const texto = buscar?.value.toLowerCase() ?? '';
      cards.forEach(card => {
        const el = card as HTMLElement;
        const nombre = el.dataset.nombre ?? '';
        const desc = el.dataset.descripcion ?? '';
        const cat = el.dataset.categoria ?? '';
        const matchTexto = !texto || nombre.includes(texto) || desc.includes(texto);
        const matchCat = categoriaActiva === 'todas' || cat === categoriaActiva.toLowerCase();
        el.style.display = matchTexto && matchCat ? '' : 'none';
      });
      catSections.forEach(sec => {
        const s = sec as HTMLElement;
        const cat = s.dataset.category ?? '';
        if (categoriaActiva !== 'todas' && cat !== categoriaActiva.toLowerCase()) {
          s.style.display = 'none';
        } else {
          s.style.display = '';
        }
      });
    }

    mozoBtn?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const api = btn.dataset.api;
      const text = btn.querySelector('.mozo-text') as HTMLElement;
      text.textContent = 'Llamando...';
      btn.classList.add('called');
      try {
        await fetch(`${api}/llamada-mozo/${btn.dataset.mesaId}`, { method: 'POST' });
        trackear('llamada_mozo');
        text.textContent = 'Mozo notificado';
        setTimeout(() => { text.textContent = 'Llamar al mozo'; btn.classList.remove('called'); }, 5000);
      } catch {
        text.textContent = 'Reintentar';
        btn.classList.remove('called');
      }
    });
  </script>
</CartaLayout>
